---
import Layout from '../layouts/Layout.astro';
import { t, locales, defaultLocale } from '../i18n/utils';

const lang = defaultLocale;
---

<Layout title={t(lang, 'error.notFound')} lang={lang}>
  <div class="flex flex-1 items-center justify-center px-6 py-24">
    <div class="text-center max-w-md">
      <p class="text-6xl font-bold text-brand-purple-600">404</p>
      <h1 class="mt-4 text-2xl font-semibold text-gray-900">{t(lang, 'error.notFound')}</h1>
      <p class="mt-4 text-gray-600">{t(lang, 'error.notFoundDescription')}</p>
      <a
        id="back-home"
        href="/fr/"
        class="mt-8 inline-block rounded-full bg-brand-purple-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-brand-purple-700 transition-colors"
      >
        {t(lang, 'error.backHome')}
      </a>
    </div>
  </div>
</Layout>

<script>
  const locales = ['fr', 'en', 'pcm'];
  const defaultLocale = 'fr';

  const [, segment] = window.location.pathname.split('/');
  const locale = locales.includes(segment) ? segment : defaultLocale;
  const homePath = `/${locale}/`;

  // Update the back-home link to match detected locale
  const link = document.getElementById('back-home');
  if (link) link.setAttribute('href', homePath);

  // Redirect to the correct locale homepage
  const meta = document.createElement('meta');
  meta.httpEquiv = 'refresh';
  meta.content = `5;url=${homePath}`;
  document.head.appendChild(meta);
</script>
