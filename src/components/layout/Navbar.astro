---
import { t, localePaths, localeNames, locales, getEquivalentPath, type Locale } from '../../i18n/utils';
import site from '../../content/settings/site.json';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
const paths = localePaths[lang];
const PLAY_STORE = site.playStoreUrl;

const navLinks = [
  { href: `${paths.home}#fonctionnalites`, label: t(lang, 'nav.features') },
  { href: paths.about, label: t(lang, 'nav.about') },
  { href: paths.contact, label: t(lang, 'nav.contact') },
  { href: paths.media, label: t(lang, 'nav.media') },
];

const localeFlags: Record<Locale, string> = {
  fr: '\u{1F1EB}\u{1F1F7}',
  en: '\u{1F1EC}\u{1F1E7}',
  pcm: '\u{1F1E8}\u{1F1F2}',
};
---

<nav class="fixed top-0 inset-x-0 z-50 bg-white border-b border-slate-200/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={paths.home} class="flex items-center">
        <img src="/images/logo-bright.png" alt="African Puzzle WORKS" class="h-10 w-auto" />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-semibold text-[rgb(61,38,100)] hover:text-brand-purple-600 dark:text-slate-300 dark:hover:text-brand-purple-400 transition-colors"
          >
            {link.label}
          </a>
        ))}

        <!-- Language Selector -->
        <div class="relative" id="lang-selector">
          <button id="lang-toggle" class="flex items-center gap-1.5 text-sm font-semibold text-[rgb(61,38,100)] hover:text-brand-purple-600 transition-colors cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 100-18 9 9 0 000 18z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.6 9h16.8M3.6 15h16.8" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3a15.3 15.3 0 014 9 15.3 15.3 0 01-4 9 15.3 15.3 0 01-4-9 15.3 15.3 0 014-9z" />
            </svg>
            {localeNames[lang]}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="lang-dropdown" class="absolute right-0 top-full mt-2 w-36 bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 opacity-0 invisible transition-all duration-200 py-2">
            {locales.map((loc) => (
              <a
                href={getEquivalentPath(currentPath, loc)}
                class:list={[
                  'flex items-center gap-2 px-4 py-2 text-sm transition-colors',
                  loc === lang
                    ? 'text-brand-purple-600 font-semibold bg-brand-purple-50 dark:bg-brand-purple-900/20'
                    : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700',
                ]}
              >
                <span class="text-base">{localeFlags[loc]}</span>
                {localeNames[loc]}
              </a>
            ))}
          </div>
        </div>

        <a
          href={PLAY_STORE}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-5 py-2.5 bg-brand-purple-600 text-white text-sm font-semibold rounded-full hover:bg-brand-purple-700 shadow-md hover:shadow-lg transition-all duration-300 hover:-translate-y-0.5"
        >
          {t(lang, 'nav.download')}
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
        aria-label="Menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900">
    <div class="px-4 py-4 space-y-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block px-4 py-3 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-brand-purple-50 dark:hover:bg-brand-purple-900/20 hover:text-brand-purple-600 font-medium transition-colors"
        >
          {link.label}
        </a>
      ))}
      <div class="border-t border-slate-200 dark:border-slate-700 pt-3">
        <p class="px-4 text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">{t(lang, 'nav.language')}</p>
        {locales.map((loc) => (
          <a
            href={getEquivalentPath(currentPath, loc)}
            class:list={[
              'flex items-center gap-2 px-4 py-2 rounded-lg text-sm transition-colors',
              loc === lang
                ? 'text-brand-purple-600 font-semibold bg-brand-purple-50 dark:bg-brand-purple-900/20'
                : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700',
            ]}
          >
            <span class="text-base">{localeFlags[loc]}</span>
            {localeNames[loc]}
          </a>
        ))}
      </div>
      <a
        href={PLAY_STORE}
        target="_blank"
        rel="noopener noreferrer"
        class="block text-center px-5 py-3 bg-brand-purple-600 text-white font-semibold rounded-full hover:bg-brand-purple-700 transition-colors"
      >
        {t(lang, 'nav.download')}
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  const langToggle = document.getElementById('lang-toggle');
  const langDropdown = document.getElementById('lang-dropdown');
  langToggle?.addEventListener('click', () => {
    langDropdown?.classList.toggle('opacity-0');
    langDropdown?.classList.toggle('invisible');
  });
  document.addEventListener('click', (e) => {
    const selector = document.getElementById('lang-selector');
    if (selector && !selector.contains(e.target as Node)) {
      langDropdown?.classList.add('opacity-0', 'invisible');
    }
  });
</script>
