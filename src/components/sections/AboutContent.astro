---
import { t, type Locale } from '../../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const teamEntries = await getCollection('team');
const team = teamEntries
  .sort((a, b) => a.data.order - b.data.order)
  .map(entry => entry.data);
---

<section class="pb-20 lg:pb-28 bg-about-tan">
  <!-- Full-bleed hero -->
  <div class="relative w-full h-[60vh] md:h-[80vh] lg:h-screen overflow-hidden">
    <img
      src="/images/about-hero.png"
      alt="African Puzzle"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 flex items-center">
      <div class="max-w-7xl mx-auto w-full px-6 sm:px-10 lg:px-16">
        <img
          src="/images/logo-white-full.svg"
          alt="African Puzzle — Find Africa everywhere"
          class="w-40 sm:w-56 md:w-72 lg:w-[360px] drop-shadow-lg"
        />
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16">

    <!-- Purple Banner with Phone -->
    <div class="bg-brand-purple-600 rounded-2xl overflow-visible relative mb-20">
      <div class="flex flex-col lg:flex-row items-center">
        <!-- Text side -->
        <div class="flex-1 px-6 py-4 lg:py-5 lg:px-12 text-white">
          <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold font-display uppercase leading-tight mb-4 whitespace-nowrap">
            {t(lang, 'about.title')}
          </h1>
          <p class="text-lg leading-relaxed opacity-90 mb-4">
            {t(lang, 'about.innovation')}
          </p>
          <p class="text-lg leading-relaxed" set:html={t(lang, 'about.creative_statement')} />
        </div>

        <!-- Phone mockup — protrudes above and below -->
        <div class="relative flex-shrink-0 px-8 lg:px-12 my-4 lg:my-0">
          <div class="lg:my-[-4rem]">
            <img
              src="/images/app-screenshot-programmes.png"
              alt="African Puzzle WORKS app"
              class="w-56 md:w-64 lg:w-72 drop-shadow-2xl"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Team -->
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold font-display text-[#340975]">
        {t(lang, 'about.team_title')}
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {team.map((member) => (
        <div class="text-center group">
          <div class="relative w-40 h-40 lg:w-[260px] lg:h-[260px] mx-auto mb-4 rounded-full bg-white flex items-center justify-center text-[#340975] text-3xl lg:text-5xl font-bold overflow-hidden shadow-lg group-hover:shadow-xl transition-shadow duration-300">
            <span>{member.name.split(' ').map(n => n[0]).join('')}</span>
            <img
              src={member.photo}
              alt={member.name}
              class="absolute inset-0 w-full h-full object-cover"
              onerror="this.style.display='none'"
            />
          </div>
          <h3 class="font-bold text-[#340975] text-lg">
            {member.name}
          </h3>
          {member.role[lang] && (
            <p class="text-sm text-[#a5a29b] mt-1">
              {member.role[lang]}
            </p>
          )}
          {member.linkedin && (
            <a
              href={member.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 mt-3 text-sm text-[#340975] hover:text-[#340975]/70 transition-colors"
            >
              LinkedIn
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
