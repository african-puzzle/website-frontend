---
import { getCollection } from 'astro:content';
import { socialIcons } from '../../lib/social-icons';

const instaPosts = (await getCollection('instagram')).sort((a, b) => a.data.order - b.data.order);
const site = (await getCollection('settings'))[0].data;
---

<section class="pb-16 lg:pb-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <a
        href={site.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-brand-purple-600 hover:text-brand-purple-700 transition-colors"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d={socialIcons.Instagram} />
        </svg>
        <span class="text-lg font-semibold">{site.instagramHandle}</span>
      </a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
      {instaPosts.map((post) => (
        <a
          href={post.data.link}
          target="_blank"
          rel="noopener noreferrer"
          class="block aspect-square overflow-hidden rounded-xl group"
        >
          <img
            src={post.data.image}
            alt="African Puzzle on Instagram"
            class="w-full h-full object-cover group-hover:scale-110 group-hover:opacity-80 transition-all duration-500"
            loading="lazy"
          />
        </a>
      ))}
    </div>
  </div>
</section>
