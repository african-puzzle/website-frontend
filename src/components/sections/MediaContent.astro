---
import { t, type Locale } from '../../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

// Placeholder media items — these would come from content collections in production
const mediaItems = Array.from({ length: 9 }, (_, i) => ({
  id: i + 1,
  title: `Media ${i + 1}`,
  color: ['from-purple-400 to-purple-600', 'from-blue-400 to-blue-600', 'from-emerald-400 to-emerald-600', 'from-amber-400 to-amber-600', 'from-rose-400 to-rose-600', 'from-cyan-400 to-cyan-600'][i % 6],
}));
---

<section class="pt-32 pb-20 lg:pb-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-brand-purple-600 font-semibold text-sm uppercase tracking-wider">
        {t(lang, 'media.label')}
      </span>
      <h1 class="mt-3 text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white">
        {t(lang, 'media.title')}
      </h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
        {t(lang, 'media.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {mediaItems.map((item) => (
        <div class="group bg-white dark:bg-slate-800 rounded-2xl overflow-hidden border border-slate-100 dark:border-slate-700 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
          <div class={`h-48 bg-gradient-to-br ${item.color} flex items-center justify-center`}>
            <svg class="w-12 h-12 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-slate-900 dark:text-white">{item.title}</h3>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
              {t(lang, 'media.press_article')}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
