---
import { t, type Locale } from '../../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const categories = [
  { key: 'radio', label: 'Radio & Podcasts' },
  { key: 'press-release', label: t(lang, 'media.filter_press_release') },
  { key: 'articles', label: 'Articles' },
  { key: 'videos', label: t(lang, 'media.filter_videos') },
  { key: 'social', label: 'Social Mention' },
];

const mediaEntries = await getCollection('media');
const mediaItems = mediaEntries
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map(entry => entry.data);

const categoryLabels: Record<string, string> = {
  radio: 'Radio & Podcasts',
  'press-release': t(lang, 'media.filter_press_release'),
  articles: 'Articles',
  videos: t(lang, 'media.filter_videos'),
  social: 'Social Mention',
};

function formatDate(dateStr: string, locale: string): string {
  const date = new Date(dateStr + 'T00:00:00');
  const localeMap: Record<string, string> = { fr: 'fr-FR', en: 'en-US', pcm: 'en-US' };
  return date.toLocaleDateString(localeMap[locale] || 'fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const ITEMS_PER_PAGE = 9;
---

<section class="pt-32 pb-20 lg:pb-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900">
        {t(lang, 'media.title')}
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        {t(lang, 'media.subtitle')}
      </p>
    </div>

    <!-- Category Filters -->
    <div class="flex flex-wrap justify-center gap-3 mb-14" id="media-filters">
      <button
        data-filter="all"
        class="filter-btn active px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200 bg-brand-purple-600 text-white"
      >
        {t(lang, 'media.filter_all')}
      </button>
      {categories.map((cat) => (
        <button
          data-filter={cat.key}
          class="filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200 bg-slate-100 text-slate-600 hover:bg-brand-purple-100 hover:text-brand-purple-700"
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Media Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8" id="media-grid">
      {mediaItems.map((item, index) => (
        <a
          href={item.link}
          target="_blank"
          rel="noopener noreferrer"
          data-category={item.category}
          data-index={index}
          class:list={[
            'media-card group bg-white rounded-2xl overflow-hidden border border-slate-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1',
            index >= ITEMS_PER_PAGE && 'hidden',
          ]}
        >
          <div class="aspect-[4/3] overflow-hidden bg-slate-100">
            <img
              src={item.image}
              alt={item.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-6">
            <span class="inline-block text-xs font-bold uppercase tracking-wider text-brand-purple-600 mb-2">
              {categoryLabels[item.category]}
            </span>
            <h3 class="font-bold text-slate-900 leading-snug group-hover:text-brand-purple-700 transition-colors">
              {item.title}
            </h3>
            {item.description && (
              <p class="mt-3 text-sm text-slate-500 line-clamp-3">
                {item.description}
              </p>
            )}
            <time class="block mt-4 text-xs text-slate-400 font-medium">
              {formatDate(item.date, lang)}
            </time>
          </div>
        </a>
      ))}
    </div>

    <!-- Load More Button -->
    <div class="text-center mt-12" id="load-more-wrapper">
      <button
        id="load-more-btn"
        class="inline-flex items-center px-8 py-3 bg-brand-purple-600 text-white font-semibold rounded-full hover:bg-brand-purple-700 shadow-md hover:shadow-lg transition-all duration-300 hover:-translate-y-0.5 cursor-pointer"
      >
        {t(lang, 'media.load_more')}
      </button>
    </div>
  </div>
</section>

<script define:vars={{ ITEMS_PER_PAGE }}>
  const filters = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.media-card');
  const loadMoreBtn = document.getElementById('load-more-btn');
  const loadMoreWrapper = document.getElementById('load-more-wrapper');
  let currentFilter = 'all';
  let visibleCount = ITEMS_PER_PAGE;

  function updateVisibility() {
    let shown = 0;
    let totalMatching = 0;

    cards.forEach((card) => {
      const matchesFilter = currentFilter === 'all' || card.dataset.category === currentFilter;

      if (!matchesFilter) {
        card.classList.add('hidden');
        return;
      }

      totalMatching++;

      if (shown < visibleCount) {
        card.classList.remove('hidden');
        shown++;
      } else {
        card.classList.add('hidden');
      }
    });

    // Show/hide load more button
    if (loadMoreWrapper) {
      loadMoreWrapper.style.display = shown < totalMatching ? '' : 'none';
    }
  }

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      currentFilter = btn.dataset.filter || 'all';
      visibleCount = ITEMS_PER_PAGE;

      // Update active state
      filters.forEach((b) => {
        b.classList.remove('active', 'bg-brand-purple-600', 'text-white');
        b.classList.add('bg-slate-100', 'text-slate-600');
      });
      btn.classList.add('active', 'bg-brand-purple-600', 'text-white');
      btn.classList.remove('bg-slate-100', 'text-slate-600');

      updateVisibility();
    });
  });

  loadMoreBtn?.addEventListener('click', () => {
    visibleCount += ITEMS_PER_PAGE;
    updateVisibility();
  });

  // Initial state
  updateVisibility();
</script>
