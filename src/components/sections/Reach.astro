---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold font-display uppercase text-center mb-16" style="color: #340975;">
      {t(lang, 'reach.title')}
    </h2>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-8 gap-y-3">
      {countries.map(([flag, ...names]) => (
        <div class="flex items-center gap-3">
          <span class="text-2xl leading-none">{flag}</span>
          <span class="text-sm text-slate-700">{names[langIndex - 1]}</span>
        </div>
      ))}
    </div>
  </div>
</section>
