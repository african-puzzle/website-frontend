---
import { t, type Locale } from '../../i18n/utils';
import { getCollection, render } from 'astro:content';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const privacyEntries = await getCollection('privacy');
const entry = privacyEntries.find((e) => e.data.locale === lang)
  ?? privacyEntries.find((e) => e.data.locale === 'fr');
const { Content } = await render(entry!);
---

<section class="pt-32 pb-20 lg:pb-28">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight" style="color: #8c30f5;">
        {entry!.data.title}
      </h1>
      <p class="mt-4 text-sm uppercase tracking-wider text-slate-400">
        {t(lang, 'privacy.effective')}
      </p>
    </div>

    <div class="prose prose-lg prose-slate max-w-none prose-headings:font-bold prose-a:underline" style="color: #3d2664;">
      <Content />
    </div>
  </div>
</section>
