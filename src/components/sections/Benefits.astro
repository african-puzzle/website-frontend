---
import { t, type Locale } from '../../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const benefits = [
  t(lang, 'benefits.efficient_title'),
  t(lang, 'benefits.time_title'),
  t(lang, 'benefits.happy_title'),
];
---

<section
  class="py-24 lg:py-36"
  style="background-color: var(--theme-bg-benefits); background-image: url('/images/speckled-block.png'); background-size: cover; background-position: center;"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="flex flex-col gap-6 sm:gap-8">
      {benefits.map((text) => (
        <p class="text-3xl sm:text-5xl lg:text-6xl font-bold uppercase text-white leading-relaxed font-display">
          {text}
        </p>
      ))}
    </div>
  </div>
</section>
