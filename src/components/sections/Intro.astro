---
import { t, type Locale } from '../../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<section class="bg-gradient-to-t from-brand-purple-900 to-brand-purple-600 py-16 lg:py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-display text-white">
      {t(lang, 'intro.title')}
    </h2>
    <p class="mt-6 text-xl sm:text-2xl text-white/90">
      {t(lang, 'intro.subtitle')}
    </p>
    <p class="mt-6 text-xl sm:text-2xl font-bold text-white uppercase tracking-wider">
      {t(lang, 'intro.audiences')}
    </p>
  </div>
</section>
