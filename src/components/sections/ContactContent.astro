---
import { t, type Locale } from '../../i18n/utils';
import { getCollection } from 'astro:content';
import { socialIcons } from '../../lib/social-icons';
import DownloadBanner from './DownloadBanner.astro';
import InstagramFeed from './InstagramFeed.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const allSocial = await getCollection('socialLinks');
const site = (await getCollection('settings'))[0].data;
const channels = allSocial
  .filter((s) => s.data.showInContact)
  .sort((a, b) => a.data.order - b.data.order)
  .map((s) => ({ name: s.data.platform, value: s.data.handle, href: s.data.url, icon: socialIcons[s.data.platform] ?? '' }));
---

<!-- Hero heading -->
<section class="pt-32 pb-12 lg:pb-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold" style="color: #3d2664;">
      {t(lang, 'contact.title')}
    </h1>
  </div>
</section>

<!-- Contact channels + address grid -->
<section class="pb-20 lg:pb-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Row 1: 4 columns -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-y-16 gap-x-8 mb-16">
      {channels.slice(0, 4).map((channel) => (
        <a
          href={channel.href}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center text-center group"
        >
          <svg class="w-14 h-14 mb-5" fill="#8c30f5" viewBox="0 0 24 24">
            <path d={channel.icon} />
          </svg>
          <div class="font-bold text-lg mb-2" style="color: #3d2664;">
            {channel.name}
          </div>
          <div class="text-base underline group-hover:no-underline" style="color: #3d2664;">
            {channel.value}
          </div>
        </a>
      ))}
    </div>

    <!-- Row 2: 3 columns (Twitter, LinkedIn, Address) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-16 gap-x-8">
      {channels.slice(4).map((channel) => (
        <a
          href={channel.href}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center text-center group"
        >
          <svg class="w-14 h-14 mb-5" fill="#8c30f5" viewBox="0 0 24 24">
            <path d={channel.icon} />
          </svg>
          <div class="font-bold text-lg mb-2" style="color: #3d2664;">
            {channel.name}
          </div>
          <div class="text-base underline group-hover:no-underline" style="color: #3d2664;">
            {channel.value}
          </div>
        </a>
      ))}

      <!-- Address block (as grid item) -->
      <div class="flex flex-col items-center text-center">
        <svg class="w-14 h-14 mb-5" fill="#8c30f5" viewBox="0 0 24 24">
          <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/>
        </svg>
        <div class="font-bold text-lg mb-2" style="color: #3d2664;">
          {t(lang, 'contact.address_company')}
        </div>
        <div class="text-base" style="color: #3d2664;">
          {t(lang, 'contact.address_street')}
        </div>
        <div class="text-base" style="color: #3d2664;">
          {t(lang, 'contact.address_city')}
        </div>
        <a
          href={`mailto:${site.contactEmail}`}
          class="mt-3 text-base underline hover:no-underline"
          style="color: #3d2664;"
        >
          {site.contactEmail}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Instagram Feed -->
<InstagramFeed />

<!-- Download CTA -->
<DownloadBanner lang={lang} />
