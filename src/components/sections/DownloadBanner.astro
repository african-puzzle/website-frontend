---
import { t, type Locale } from '../../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const site = (await getCollection('settings'))[0].data;
const playStoreUrl = site.playStoreUrl;
---

<section class="download-banner relative w-full overflow-hidden" style="background-color: #67A097;">
  <div class="flex flex-col md:flex-row items-stretch">
    <!-- Image (top on mobile, right on desktop) -->
    <div class="w-full md:w-1/2 md:order-2">
      <img
        src="/images/moussa-tailor.jpg"
        alt="Tailor using African Puzzle app"
        class="w-full h-auto block"
        loading="lazy"
      />
    </div>

    <!-- Text + Badge (bottom on mobile, left on desktop) -->
    <div class="w-full md:w-1/2 md:order-1 flex flex-col items-center justify-center px-8 py-12">
      <h2
        class="text-center max-w-md font-semibold leading-tight mb-8"
        style="color: #3d2664; font-size: clamp(1.75rem, 4vw, 2.4rem);"
      >
        {t(lang, 'download_banner.title')}
      </h2>
      <a href={playStoreUrl} target="_blank" rel="noopener noreferrer">
        <img
          src="/images/google-play-badge.svg"
          alt="Get it on Google Play"
          class="h-14 md:h-16 hover:opacity-80 transition-opacity"
        />
      </a>
    </div>
  </div>
</section>
