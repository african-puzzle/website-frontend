---
import { t, type Locale } from '../../i18n/utils';
import PhoneFrame from '../ui/PhoneFrame.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const features = [
  {
    title: t(lang, 'features.projects.title'),
    desc: t(lang, 'features.projects.desc'),
    gif: '/images/features/projects.gif',
    cardBg: 'bg-feature-projects',
  },
  {
    title: t(lang, 'features.clients.title'),
    desc: t(lang, 'features.clients.desc'),
    gif: '/images/features/clients.gif',
    cardBg: 'bg-feature-clients',
  },
  {
    title: t(lang, 'features.album.title'),
    desc: t(lang, 'features.album.desc'),
    gif: '/images/features/album.gif',
    cardBg: 'bg-feature-album',
  },
  {
    title: t(lang, 'features.appointments.title'),
    desc: t(lang, 'features.appointments.desc'),
    gif: '/images/features/appointments.gif',
    cardBg: 'bg-feature-appointments',
  },
];
---

<section
  id="fonctionnalites"
  class="py-20 lg:py-28 overflow-hidden"
  style="background-color: #1a7a6d; background-image: url('/images/features-texture.svg'); background-size: cover;"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-white/70 font-semibold text-sm uppercase tracking-wider">
        {t(lang, 'features.label')}
      </span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold font-display text-white">
        {t(lang, 'features.title')}
      </h2>
      <p class="mt-4 text-lg text-white/80">
        {t(lang, 'features.subtitle')}
      </p>
    </div>

    <!-- Feature cards with phone mockups -->
    <div class="space-y-28 lg:space-y-32">
      {features.map((feature, index) => (
        <div class={`${feature.cardBg} rounded-2xl overflow-visible relative`}>
          <div class={`flex flex-col ${index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} items-center`}>
            <!-- Text side -->
            <div class="flex-1 px-6 py-4 lg:py-5 lg:px-12">
              <h3 class="text-3xl lg:text-5xl font-bold font-display text-slate-900 uppercase mb-2">
                {feature.title}
              </h3>
              <p class="text-xl lg:text-2xl text-slate-700 leading-relaxed max-w-md">
                {feature.desc}
              </p>
            </div>

            <!-- Phone mockup side — vertically centered, protruding equally top & bottom -->
            <div class="relative flex-shrink-0 px-8 lg:px-12 my-4 lg:my-0 lg:-top-0">
              <div class="lg:my-[-4rem]">
                <PhoneFrame src={feature.gif} alt={feature.title} />
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
